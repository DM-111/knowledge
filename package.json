{
  "name": "knowledge",
  "version": "0.1.0",
  "description": "Local-first knowledge service CLI.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "bin": {
    "kb": "./bin/kb.js"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/copy-storage-assets.mjs",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
